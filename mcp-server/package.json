{
  "name": "opendart-mcp-server",
  "version": "1.0.0",
  "description": "회사명을 받아 최근 DART 공시를 사실 중립 요약으로 반환하는 MCP 서버",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "opendart-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build:corp-index": "node scripts/build-corp-index.mjs",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
